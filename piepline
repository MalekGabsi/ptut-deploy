pipeline {
    agent any
    parameters{
        string(name:'GIT_URL')
    }
    stages {
        stage ('Clone') {
            steps{
                echo "récupération de code "
                sh 'git clone ${GIT_URL}'
            }
            
        }
        
        stage ('Test'){
            steps {
                echo "lancement des tests"
                sh 'npm run test'
            }
            
        }
        stage ('Docker build'){
            steps{
                echo "Construire image docker"
                sh 'docker build -t image'
            }
            
        }

        post{
                failure{
                    mail([to:"" , subject : "erreur"])
                }
            }

    }

}